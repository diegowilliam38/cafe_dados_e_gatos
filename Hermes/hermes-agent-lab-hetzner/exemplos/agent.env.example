# Hermes Agent / Gateway API
# Caminho real na VPS:
# ~/.hermes/.env

NODE_ENV=production
HOST=127.0.0.1
API_PORT=8642
DASHBOARD_PORT=9119

# Chave técnica da API.
# Não é senha de login.
API_SERVER_KEY=TROQUE_ESTA_CHAVE_API

# Ollama local
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# SearXNG local
SEARXNG_BASE_URL=http://127.0.0.1:8080

# Dashboard
DASHBOARD_HOST=127.0.0.1
DASHBOARD_BASE_URL=http://127.0.0.1:9119

