# Hermes Workspace
# Caminho real na VPS:
# ~/hermes-workspace/.env

NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# URL do Hermes Agent / Gateway API.
HERMES_API_URL=http://127.0.0.1:8642

# Deve ter o mesmo valor de API_SERVER_KEY em ~/.hermes/.env.
HERMES_API_TOKEN=TROQUE_ESTA_CHAVE_API

# Senha usada para entrar no Workspace pelo navegador.
HERMES_PASSWORD=TROQUE_ESTA_SENHA_DO_WORKSPACE

# Em HTTP, use 0. Em HTTPS corretamente configurado, use 1.
COOKIE_SECURE=0

